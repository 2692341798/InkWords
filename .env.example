# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# 后端限流与并发配置 (适配 DeepSeek V4)
MAX_CONCURRENT_WORKERS=50
LLM_API_RPM_LIMIT=10000

# 数据库配置
DATABASE_URL=postgres://postgres:postgres@postgres:5432/inkwords?sslmode=disable

# JWT 密钥
JWT_SECRET=your_jwt_secret_here

# GitHub OAuth 配置
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost/api/v1/auth/callback/github
